---
import Layout from "../layouts/Layout.astro";
import "../styles/circleImg.scss";
---

<Layout>
    <!-- Image -->
    <div
        class="max-sm:max-w-[88%] max-sm:h-fit flex justify-around max-md:flex-col max-md:justify-between items-center"
    >
        <div
            class="w-full max-w-[35%] h-[100%] max-md:max-w-[90%] max-md:h-fit flex justify-around items-center"
        >
            <div class="circle-large"></div>
        </div>

        <!-- About me -->
        <div
            class="w-full max-w-[48%] h-[100%] max-md:max-w-[90%] max-md:h-fit max-sm:max-w-[90%] max-sm:h-fit p-6 bg-primary flex flex-col justify-around items-center rounded-md shadow-acent"
        >
            <header
                class="text-acentOrange text-39 max-md:text-39md max-sm:text-39sm font-orbitron font-black"
            >
                About Me
            </header>
            <p
                class="text-secondary text-30 max-md:text-30md max-sm:text-30sm text-center font-code"
            >
                Full-Stack Software Engineer building production-ready web
                applications with React, Node.js, MongoDB, and Docker.
                Experienced in developing REST APIs, responsive frontend
                systems, and deploying containerized applications on VPS
                environments using Nginx and SSL. Built and deployed multiple
                full-stack applications independently, owning the full
                development lifecycle from architecture and UI to backend
                systems and production deployment.
            </p>
        </div>
    </div>
</Layout>
